# Copy this file to .env and fill in real values.
# Never commit .env — it's in .gitignore.

# ==== MetaTrader 5 demo account ====
# Exness demo: log in to https://www.exness.com, open a demo MT5 account, and
# the next page shows your login (8-digit), password, and server name (one of
# Exness-MT5Trial / Exness-MT5Trial4 / Exness-MT5Trial6).
MT5_LOGIN=12345678
MT5_PASSWORD=your_demo_password
MT5_SERVER=Exness-MT5Trial
# Exness branded build installs here; if you used the generic MT5 installer
# instead, use C:\Program Files\MetaTrader 5\terminal64.exe.
MT5_PATH=C:\Program Files\Exness MetaTrader 5\terminal64.exe

# ==== API auth ====
# Required. HS256 JWT sign key + Fernet KDF input for broker creds at rest.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# install.ps1 generates one automatically if this slot is empty.
# Rotating invalidates every session and saved broker password.
AUTH_SECRET=

# ==== Operator setup-link email (optional — only if you'll add users via the dashboard) ====
# Gmail: generate an App Password at https://myaccount.google.com/apppasswords (needs 2FA on).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_STARTTLS=1
PUBLIC_BASE_URL=http://localhost:8000

# ==== Trading configuration ====
SYMBOLS=EURUSD,GBPUSD,USDJPY
TIMEFRAME=M15
RISK_PER_TRADE=0.01
MAX_OPEN_TRADES=3
MAX_DAILY_LOSS_PCT=0.05

# ==== Telegram alerts ====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ==== Logging ====
LOG_LEVEL=INFO

# ==== Execution mode ====
# Set to 1 on the Windows VPS to trade via MetaTrader5. Left at 0, main.py
# runs the mock feed/executor — safe for local development.
USE_MT5=0

# ==== ML signal filter ====
# Path to the trained XGBoost model. If the file doesn't exist, the bot runs
# without a filter (same behavior as before the ML layer was added).
ML_MODEL_PATH=data/models/signal_filter.json
# Minimum P(win) to take a trade. Raise to be more selective.
ML_THRESHOLD=0.55

# ==== Economic-calendar blackout ====
# Blocks new trades around high-impact releases (NFP, CPI, FOMC, …). Events
# are pulled from the ForexFactory public weekly JSON feed on startup and
# refreshed in the background.
#
# Set to 0 to disable the whole feature — RiskManager will stop consulting
# the calendar and /calendar/blackout/<symbol> will report enabled=false.
CALENDAR_BLACKOUT_ENABLED=1
# Minutes before an event to start blocking new trades on affected symbols.
CALENDAR_BLACKOUT_BEFORE_MIN=15
# Minutes after an event before resuming.
CALENDAR_BLACKOUT_AFTER_MIN=15
# Comma-separated impact levels that trigger a blackout: high,medium,low.
# Default is high-only, matching most manual traders' rules.
CALENDAR_BLACKOUT_IMPACTS=high
# Seconds between background refreshes of the calendar cache. 1800 = 30 min.
CALENDAR_REFRESH_INTERVAL_S=1800

# ==== Market-regime classifier ====
# ADX-driven trend detector plus ATR-percentile volatility tag. The Bot uses
# it to gate strategies whose `preferred_regimes` don't include the current
# trend (mean-reversion in strong trends, breakouts in dead chop, etc.). The
# latest snapshot per symbol is exposed via GET /regime/{symbol}.
#
# Set to 0 to disable — strategies then fire regardless of regime.
REGIME_ENABLED=1
# ADX period for the directional movement calc. 14 is Wilder's original.
REGIME_ADX_PERIOD=14
# ADX threshold separating "trending" from "ranging". Below = range, above =
# trend_up or trend_down depending on +DI vs -DI. Raise for a stricter trend
# definition (fewer signals get through to trend strategies).
REGIME_ADX_TREND_THRESHOLD=22
# ATR period + lookback window used to rank current volatility. The classifier
# computes ATR's percentile rank inside the trailing `REGIME_ATR_LOOKBACK`
# bars and tags the result as low/normal/high.
REGIME_ATR_PERIOD=14
REGIME_ATR_LOOKBACK=100
# Percentile cutoffs for the volatility tag. Default: bottom 30% = low,
# top 30% = high, middle 40% = normal.
REGIME_ATR_LOW_PCT=0.30
REGIME_ATR_HIGH_PCT=0.70

# ==== Portfolio correlation throttle ====
# Blocks pile-on trades that would push correlated portfolio heat past a
# ceiling. Two BUYs on EURUSD + GBPUSD (ρ ≈ 0.8) are not two independent
# bets — the throttle catches that. The Bot recomputes the correlation
# matrix every CORRELATION_REFRESH_TICKS poll cycles and writes it to
# data/trades.db, where the throttle (held by RiskManager) reads from it.
#
# Set to 0 to disable — RiskManager stops consulting the throttle and
# /correlation returns whatever's in the store (possibly empty).
CORRELATION_ENABLED=1
# Window of bars used to compute pairwise log-return correlation. 200 ≈
# ~2 trading days on M15. Longer = smoother, slower to react to regime
# shifts.
CORRELATION_WINDOW_BARS=200
# Minimum overlapping observations (after inner-join alignment) required
# before a pair correlation is reported. Below this, the pair is dropped.
CORRELATION_MIN_OBS=50
# How often the Bot recomputes + persists the matrix, measured in poll
# ticks. With poll_interval_s=10, 60 ticks = 10 min.
CORRELATION_REFRESH_TICKS=60
# Maximum allowed sum of (open_position_risk × effective_correlation) +
# new candidate risk, expressed as a fraction of equity. Default 0.04 =
# the throttle starts blocking when correlated heat would top 4%.
CORRELATION_MAX_HEAT_PCT=0.04
# Below this absolute correlation, pairs are treated as uncorrelated (no
# contribution). Avoids the throttle nibbling on noise.
CORRELATION_FLOOR=0.30
# What to assume when a pair is missing from the store. Default 1.0 is
# conservative (treat unknown as fully correlated). Set to 0.0 for the
# permissive option that lets unfamiliar symbols trade freely.
CORRELATION_UNKNOWN=1.0

# ==== Live-vs-backtest drift monitor ====
# Compares the bot's live trade outcomes against a stored backtest
# baseline so you can spot alpha decay before it bleeds out the account.
# Seed the baselines once with:
#     python scripts/build_baseline.py --symbol EURUSD --strategy all \
#         --since 2023-01-01 --until 2024-01-01
# The /drift endpoint and dashboard then show ok/warn/danger per pair.
#
# This is opt-in monitoring — the bot runs identically whether or not
# baselines exist. No CPU is spent if /drift is never queried (the
# endpoint is the only consumer of the monitor).
#
# How many recent CLOSED trades define the live window per pair. Smaller
# windows react faster to degradation but are noisier; 50 is a sane mix.
DRIFT_LIVE_TRADES_WINDOW=50
# Minimum live trades before the comparison fires. Below this, status
# stays 'unknown' (no false alarms on a 2-trade sample).
DRIFT_MIN_LIVE_TRADES=10
# Win-rate / avg-R drift below this is treated as noise (status=ok).
DRIFT_WARN_DELTA=0.10
# Above this, status flips to 'danger' (the strategy is materially off).
DRIFT_DANGER_DELTA=0.20
# How long the API memoizes the drift report. The dashboard polls every
# few seconds and recomputing each time would mean N small SQLite scans
# per call. 60s = at most one scan per minute regardless of poll volume.
DRIFT_CACHE_TTL_S=60

# ==== Execution-quality log ====
# Records every order open/close fill: requested vs filled price, slippage
# in pips, broker latency, and rejections. The dashboard reads aggregates
# so you can see whether the broker's getting worse before P&L tells you.
#
# Cost on the bot: one extra small SQLite INSERT per fill (~milliseconds at
# retail trade volumes). Set to 0 to disable — the hot path skips the
# write entirely when off, so the feature is zero-cost when disabled.
EXEC_QUALITY_ENABLED=1
# How long /fills/stats memoizes the GROUP-BY aggregate. The dashboard
# polls every few seconds; 30s = at most one scan every half minute.
EXEC_QUALITY_CACHE_TTL_S=30

# ---------- Champion-challenger auto-allocator ----------
# Per-(strategy, symbol) risk weighting based on rolling realised R from
# the journal. The bot scores each variant from the last N closed trades,
# picks a champion per symbol, and dials lot size for laggards down to a
# small probe so they keep collecting data without bleeding real money.
#
# Off by default. Cost when off: zero — the bot's tick loop short-circuits
# on the None check. Cost when on: one indexed SQLite query per pair every
# ALLOCATOR_REFRESH_TICKS, then nothing until the next refresh.
ALLOCATOR_ENABLED=0
# How many closed trades define each variant's score. Smaller = adapts
# faster to regime shifts; larger = more stable but slower to react.
ALLOCATOR_SCORE_WINDOW=30
# How often (in tick cycles) the bot recomputes weights. 60 ticks at the
# default 60s poll = once per hour.
ALLOCATOR_REFRESH_TICKS=60
# Below this many closed trades for a (strategy, symbol), the variant
# stays cold (weight 0). Stops a brand-new strategy from grabbing full
# risk on noise.
ALLOCATOR_MIN_SAMPLES=15
# Avg-R gap from champion within which a variant keeps mid weight. Wider
# = more variants run at meaningful size; tighter = sharper culling.
ALLOCATOR_CHALLENGER_TOLERANCE=0.20
# Weights for each role. Defaults: champion full risk, challenger half,
# probe a sliver, cold zero. Sum doesn't need to equal anything — this is
# a per-trade multiplier, not a portfolio split.
ALLOCATOR_CHAMPION_WEIGHT=1.0
ALLOCATOR_CHALLENGER_WEIGHT=0.5
ALLOCATOR_PROBE_WEIGHT=0.1
# If even the best variant on a symbol is below this avg-R, *nothing*
# trades full size — everything drops to probe weight. The kill switch
# for "all variants are bleeding".
ALLOCATOR_FLOOR_AVG_R=-0.10
# How long /allocator memoizes its read. The dashboard polls every few
# seconds; 30s keeps the SQLite read off the hot path.
ALLOCATOR_CACHE_TTL_S=30

# ---------- Explain-this-trade ----------
# Captures the decision context (regime, allocator weight, signal levels,
# account state) for each trade as it opens, so the dashboard can show
# "why did the bot take this?" later. Capture-at-write — old trades stay
# blank; only trades opened after this lands have explanations.
#
# Cost: one tiny SQLite INSERT per opened trade. On a VPS, negligible.
# Set to 0 to skip the writes; the API will return 404 for every trade.
EXPLANATIONS_ENABLED=1
